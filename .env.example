# --- [ AUTHENTICATION ] ---
# Set your custom credentials for the web terminal access
USERNAME=admin
PASSWORD=admin

# --- [ SYSTEM CONFIG ] ---
# Internal port for ttyd
PORT=7681
# Environment mode
NODE_ENV=production

# --- [ AI AGENT CONFIG ] ---
# Preferred Claude model for job analysis and CV tailoring
CLAUDE_MODEL=claude-3-5-sonnet-latest

# --- [ OPTIONAL ] ---
# You can add your Anthropic API Key here if you prefer 
# not to use the interactive 'claude' login (manual method)
ANTHROPIC_API_KEY=xxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx